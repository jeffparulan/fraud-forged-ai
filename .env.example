# ============================================================
# FraudForge AI - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it's in .gitignore for security
# ============================================================

# ============================================================
# HUGGING FACE (REQUIRED)
# ============================================================
# Get your token from: https://huggingface.co/settings/tokens
# Used for embeddings + optional HF Inference (e.g. banking Qwen path).
# Medical Stage 1 is local MedGemma (see MEDGEMMA_LOCAL_* below), not HF Inference.
HUGGINGFACE_API_TOKEN=hf_your_token_here

# ============================================================
# OPENROUTER (RECOMMENDED — ecommerce / supply-chain / medical Stage 2)
# ============================================================
# Get your key from: https://openrouter.ai/keys
# Model IDs / routing live in backend/app/llm/models.yaml (single source of truth).
# OpenRouter FREE: nemotron_ultra / super / nano_* in models.yaml
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Optional OpenRouter metadata
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_APP_NAME=FraudForge AI

# ============================================================
# LOCAL MEDGEMMA (RECOMMENDED — medical Stage 1 clinical validation)
# ============================================================
# Mac Mini via Ollama + ngrok. Never commit real values.
# Backend reads these at call time; free-tier ngrok URLs change when the tunnel restarts.
# Header X-API-Key is sent automatically; also requires ngrok-skip-browser-warning.
MEDGEMMA_LOCAL_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app
MEDGEMMA_LOCAL_API_KEY=your-local-medgemma-api-key

# Optional: set to 0 to skip Stage 2 Nemotron and blend billing rules only.
MEDICAL_TRY_STAGE2_LLM=1

# ============================================================
# PINECONE (REQUIRED for RAG)
# ============================================================
# Get your API key from: https://app.pinecone.io/
# Create a free Starter index (1 pod, 100K vectors)
PINECONE_API_KEY=pcsk_your_key_here
PINECONE_INDEX_NAME=fraudforge-master
PINECONE_HOST=https://your-index-xxxxx.svc.region.pinecone.io

# ============================================================
# GOOGLE CLOUD (OPTIONAL - for GCP deployment only)
# ============================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_API_KEY=your-gcp-api-key

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
# API URL - for local dev, use localhost
# For production, this is set automatically by Cloud Run
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# BACKEND CONFIGURATION
# ============================================================
# Port for FastAPI (Cloud Run uses 8080)
PORT=8080

# Python environment
PYTHONUNBUFFERED=1

# Kill switch (for emergency shutdown in production)
KILL_SWITCH_ENABLED=false

# ============================================================
# MCP (OPTIONAL — enables enrich_mcp stage / mcp: ok in trace)
# ============================================================
# Local docker-compose sets this automatically to http://mcp:8080.
# Host-run backend (uvicorn outside compose): use the published port:
#   MCP_SERVER_URL=http://localhost:8081
# Leave unset to soft-fail with mcp: disabled (pipeline still works).
# MCP_SERVER_URL=http://localhost:8081

# ============================================================
# BACKEND SECURITY
# ============================================================
# CORS: comma-separated list of allowed origins.
# Local dev default covers localhost:3000. In production set this to your
# frontend Cloud Run URL. Use "*" only for open demos.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional API key: when set, /api/detect requires an X-API-Key header.
# Leave empty to run as an open demo.
FRAUDFORGE_API_KEY=

# Server-side rate limit for /api/detect (per client IP)
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# TERRAFORM DEPLOYMENT (for GCP deployment)
# ============================================================
# Copy these to infrastructure/terraform.tfvars
# See infrastructure/terraform.tfvars.example for details

# TF_VAR_project_id=your-gcp-project-id
# TF_VAR_region=us-central1
# TF_VAR_huggingface_token=${HUGGINGFACE_API_TOKEN}
# TF_VAR_openrouter_key=${OPENROUTER_API_KEY}
# TF_VAR_pinecone_api_key=${PINECONE_API_KEY}
# TF_VAR_pinecone_index_name=${PINECONE_INDEX_NAME}
# TF_VAR_pinecone_host=${PINECONE_HOST}
# ============================================================
# NOTES
# ============================================================
# 1. FREE TIER LIMITS:
#    - HuggingFace: ~100-300 requests/hour (free)
#    - OpenRouter: Limited by provider quotas (free tier)
#    - Pinecone: 100K vectors, 1 pod (free Starter plan)
#    - GCP Cloud Run: 2M requests/month (free tier)
#
# 2. REQUIRED FOR LOCAL DEV:
#    - HUGGINGFACE_API_TOKEN (required)
#    - PINECONE_API_KEY + INDEX_NAME + HOST (required)
#    - OPENROUTER_API_KEY (recommended — Stage 2 / non-medical sectors)
#    - MEDGEMMA_LOCAL_BASE_URL + MEDGEMMA_LOCAL_API_KEY (recommended — medical Stage 1)
#
# 3. REQUIRED FOR GCP DEPLOYMENT:
#    - All of the above
#    - GCP_PROJECT_ID (your GCP project)
#    - terraform.tfvars (see infrastructure/terraform.tfvars.example)
#
# 4. SECURITY:
#    - Never commit .env to Git
#    - Rotate API keys regularly
#    - Use Secret Manager for production
#    - Use placeholders only in .env.example
#    - Enable 2FA on all accounts
# ============================================================
