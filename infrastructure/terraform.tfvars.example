# Copy this file to terraform.tfvars and update with your values
# IMPORTANT: terraform.tfvars is in .gitignore - NEVER commit it with real secrets!

# Required
project_id = "your-gcp-project-id"
region     = "us-central1"
app_name   = "fraud-forge"

# Optional
enable_public_access = true
github_owner          = "your-github-username"
github_repo           = "fraud-forged-ai"
billing_account_id    = ""
notification_channels = []
environment          = "prod"

# Required API Keys (fill in your actual values - NEVER commit these!)
huggingface_token = "your-huggingface-token-here"
openrouter_key    = "your-openrouter-key-here"
pinecone_api_key  = "your-pinecone-api-key-here"
pinecone_host     = "your-pinecone-host-here"

# Optional
medgemma_url       = ""
gcp_api_key       = ""
pinecone_index_name = "fraudforge-master"

# Security (recommended settings shown)
use_secret_manager = true                  # store keys in GCP Secret Manager (~$0.06/secret/mo); false = plain env vars
allowed_origins    = "*"                   # tighten to your frontend URL after first deploy, e.g. "https://fraud-forge-frontend-xxxx.run.app"
fraudforge_api_key = ""                    # optional: require X-API-Key on /api/detect (empty = open demo)

